# ============================================================
# Backend environment — copy to backend/.env and fill values
# Most vars have working defaults for Docker local dev.
# ============================================================

# Secret key for JWT token signing (any long random string)
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Email (optional — project submissions still work without it)
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM_EMAIL=noreply@panorama-sdg.org
SMTP_FROM_NAME=Panorama SDG

# Admin notification email
ADMIN_EMAIL=admin@uia.org

# reCAPTCHA (leave blank to disable)
RECAPTCHA_SECRET_KEY=
