# ============================================================
# Panorama SDG — Docker Handoff Environment Template
# ============================================================
# Copy this file to backend/.env and fill in the values.
# Generate SECRET_KEY with:  openssl rand -hex 32
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=panorama_sdg

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password

# Backend
DATABASE_URL=postgresql://postgres:changeme_strong_password@db:5432/panorama_sdg
SECRET_KEY=replace_with_output_of_openssl_rand_hex_32
ADMIN_EMAIL=admin@your-organization.org
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MinIO (must match MINIO_ROOT_USER/PASSWORD above)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_strong_password
MINIO_BUCKET=project-images
MINIO_PUBLIC_URL=http://localhost:9000

# Email (optional — leave as placeholders if not used)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=placeholder-password
SMTP_FROM_EMAIL=noreply@your-organization.org
SMTP_FROM_NAME=Panorama SDG

# reCAPTCHA (disabled by default)
ENABLE_RECAPTCHA=false
RECAPTCHA_SECRET_KEY=placeholder

# Supabase (not used in Docker — leave blank)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
