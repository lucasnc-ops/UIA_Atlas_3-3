# ============================================================
# Panorama SDG — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the .env file.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://atlas_user:atlas_pass@db:5432/atlas_db

# --- Admin access (single API key, no user accounts) ---
ADMIN_API_KEY=change-me-in-production
ADMIN_EMAIL=admin@panorama-sdg.org

# --- Image storage (MinIO, S3-compatible) ---
MINIO_ROOT_USER=atlas_minio
MINIO_ROOT_PASSWORD=atlas_minio_pass
# Public URL where browsers fetch images from MinIO
IMAGE_BASE_URL=http://localhost:9000/project-images

# --- Frontend (served by Vite / Vercel) ---
VITE_API_URL=http://localhost:8080
VITE_IMAGE_BASE_URL=http://localhost:9000/project-images

# --- Email (optional — submissions still work without it) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM_EMAIL=noreply@panorama-sdg.org
SMTP_FROM_NAME=Panorama SDG

# --- reCAPTCHA (set ENABLE_RECAPTCHA=false to skip) ---
ENABLE_RECAPTCHA=false
RECAPTCHA_SECRET_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGIN_REGEX=

# --- Runtime ---
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
